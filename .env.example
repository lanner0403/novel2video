# 複製為 .env（放在專案根目錄）。後端啟動時會自動讀取，
# 不論用 run.sh / run.bat 或手動 uvicorn 都生效。
# 預設全部 mock=true，可離線跑通整條流水線；要接真實服務再改對應的 *_MOCK。

# =========================================================
# 範例：LLM 指向本地 Ollama（OpenAI 相容端點）
# 先確認 Ollama 在跑，且已 pull 模型：  ollama pull qwen2.5:7b
# =========================================================
N2V_LLM_MOCK=false
N2V_LLM_BASE_URL=http://127.0.0.1:11434/v1
N2V_LLM_MODEL=qwen2.5:7b
N2V_LLM_API_KEY=ollama          # Ollama 不驗證，填任意非空字串即可（留空也行）
N2V_LLM_TIMEOUT=300             # 讀取逾時(秒)。本地模型產整章分鏡很慢時可再調高（分鏡逾時就改這個）
N2V_STORYBOARD_BATCH=4          # 分鏡分批：每批送幾段給 LLM。越小每批 JSON 越短、越不易壞；<=0 表示整章一次送
N2V_CHARACTER_BATCH=12          # 角色擷取分批：每批送幾段抽角色再聯集（長章節才不會漏後段角色）；<=0 整章一次送

# ---- 本地 Stable Diffusion（HuggingFace diffusers，直接在本機推理）----
# 真實出圖需先：pip install -r backend/requirements-diffusers.txt
N2V_SD_MOCK=true
N2V_SD_MODEL=stabilityai/stable-diffusion-2-1
N2V_SD_PIPELINE=auto           # auto（依模型名含 xl 判斷）/ sd / sdxl
N2V_SD_VAE=                    # 外掛 VAE：HF id、diffusers 目錄、或本地單檔 .safetensors/.ckpt 皆可
                               #（SDXL 用 fp16 必要；留空會自動套 fix）
N2V_SD_WIDTH=768
N2V_SD_HEIGHT=1344
N2V_SD_STEPS=30
N2V_SD_CFG=7.5
N2V_SD_DEVICE=auto              # auto / cuda / mps / cpu
N2V_SD_CPU_OFFLOAD=false        # 低顯存時設 true：分層 offload 到 CPU（僅 cuda 生效，較省 VRAM 但稍慢）
# N2V_SD_SEED=12345             # 固定全域種子（留空＝隨機）

# 切換 SDXL 範例（記得把尺寸改成 1024 系；VAE 留空會自動套 fp16-fix）：
# N2V_SD_MODEL=stabilityai/stable-diffusion-xl-base-1.0
# N2V_SD_VAE=madebyollin/sdxl-vae-fp16-fix
# N2V_SD_WIDTH=832
# N2V_SD_HEIGHT=1216

# ---- 本地 ComfyUI（圖生影）----
N2V_COMFY_MOCK=true
N2V_COMFY_BASE_URL=http://127.0.0.1:8188
N2V_COMFY_WORKFLOW=svd_i2v.json
# 可改用內附的 LTX-2.3 圖生影工作流（需在 ComfyUI 裝好對應自訂節點與模型）：
# N2V_COMFY_WORKFLOW=ltx2_i2v.json
# 模板佔位字串：%IMAGE%（首幀）/ %PROMPT%（鏡頭動態）/ %DURATION%（每鏡頭秒數，整數）

# ---- 其他可選的 OpenAI 相容端點（擇一）----
# OpenAI:    N2V_LLM_BASE_URL=https://api.openai.com/v1     N2V_LLM_MODEL=gpt-4o-mini
# DeepSeek:  N2V_LLM_BASE_URL=https://api.deepseek.com/v1   N2V_LLM_MODEL=deepseek-chat
